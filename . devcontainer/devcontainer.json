{
  "name": "ReThink Flutter",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "jdk": "ms"
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.flutter",
        "Dart-Code.dart-code"
      ],
      "settings": {
        "dart.flutterSdkPath": "/home/vscode/flutter",
        "dart.sdkPath": "/home/vscode/flutter/bin/cache/dart-sdk"
      }
    }
  },
  "remoteEnv": {
    "PATH": "/home/vscode/flutter/bin:/home/vscode/android-sdk/cmdline-tools/latest/bin:/home/vscode/android-sdk/platform-tools:${PATH}",
    "ANDROID_SDK_ROOT": "/home/vscode/android-sdk",
    "ANDROID_HOME": "/home/vscode/android-sdk"
  }
}
